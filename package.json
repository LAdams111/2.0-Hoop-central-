    "cheerio": "^1.0.0",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "https-proxy-agent": "^7.0.6",
    "pg": "^8.11.3",
    "puppeteer": "^24.37.5"
  }
}
